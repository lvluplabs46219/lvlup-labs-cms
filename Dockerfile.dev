FROM ruby:3.2.11

# Install PostgreSQL client for database tasks
RUN apt-get update -qq && apt-get install -y postgresql-client && rm -rf /var/lib/apt/lists/*

WORKDIR /rails

# Install gems
COPY Gemfile Gemfile.lock ./
RUN bundle install

# Copy the rest of the application
COPY . .

EXPOSE 4000

CMD ["bundle", "exec", "rails", "server", "-b", "0.0.0.0", "-p", "4000"]