# Auto-detect text files  
* text=auto  
*.rb text eol=lf  
*.ts text eol=lf  
*.tsx text eol=lf  
*.js text eol=lf  
*.json text eol=lf  
*.yml text eol=lf  
*.yaml text eol=lf  
*.md text eol=lf  
*.sh text eol=lf  
*.bat text eol=crlf  
*.ps1 text eol=crlf  
*.png binary  
*.jpg binary 
*.kt text eol=lf
*.kts text eol=lf
*.gradle text eol=lf
*.properties text eol=lf